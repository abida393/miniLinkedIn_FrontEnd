<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

  <display-name>IGA Network Platform</display-name>
  
  <context-param>
    <param-name>API_BASE_URL</param-name>
    <param-value>http://localhost:8000/api</param-value>
  </context-param>

  <!-- Default welcome page -->
  <welcome-file-list>
    <welcome-file>pages/login.jsp</welcome-file>
  </welcome-file-list>

  <!-- Auth Filter - protects all pages except login -->
  <filter>
    <filter-name>AuthFilter</filter-name>
    <filter-class>com.iga.network.filters.AuthFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/pages/home.jsp</url-pattern>
  </filter-mapping>
  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/pages/profile.jsp</url-pattern>
  </filter-mapping>
  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/pages/projects.jsp</url-pattern>
  </filter-mapping>
  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/pages/messages.jsp</url-pattern>
  </filter-mapping>
  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/pages/notifications.jsp</url-pattern>
  </filter-mapping>
  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/pages/admin.jsp</url-pattern>
  </filter-mapping>

  <!-- Login Servlet -->
  <servlet>
    <servlet-name>LoginServlet</servlet-name>
    <servlet-class>com.iga.network.servlets.LoginServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/auth/login</url-pattern>
  </servlet-mapping>

  <!-- Logout Servlet -->
  <servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>com.iga.network.servlets.LogoutServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/auth/logout</url-pattern>
  </servlet-mapping>

  <!-- Session timeout: 60 minutes -->
  <session-config>
    <session-timeout>60</session-timeout>
  </session-config>

  <!-- Error pages -->
  <error-page>
    <error-code>404</error-code>
    <location>/pages/error.jsp</location>
  </error-page>
  <error-page>
    <error-code>500</error-code>
    <location>/pages/error.jsp</location>
  </error-page>

</web-app>