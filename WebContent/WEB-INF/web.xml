  <servlet>
    <servlet-name>LoginServlet</servlet-name>
    <servlet-class>com.iga.network.servlets.LoginServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/auth/login</url-pattern>
  </servlet-mapping>

  <!-- Logout Servlet -->
